# Use local output base (avoids NFS issues)
startup --output_user_root=../.bazel

# C++26 flags
build --cxxopt=-std=gnu++26
build --cxxopt=-Wall
build --cxxopt=-Wextra  
build --cxxopt=-Wno-vla-cxx-extension
build --copt=-O3
build --copt=-march=native

# Also apply to tools (exec configuration)
build --host_cxxopt=-std=gnu++26
build --host_cxxopt=-Wno-vla-cxx-extension

# Hermetic LLVM toolchain provided by toolchains_llvm_bootstrapped
# No system compiler required - fully reproducible builds

# Hermetic Koka toolchain - no system koka required

# Temporarily use a locally built Koka compiler instead of the hermetic
# release (NON-HERMETIC; for testing compiler fixes, e.g. the specializer
# fix in ../koka). Adjust the path to your dev build:
build:koka-local --repo_env=KOKA_LOCAL_PATH=/repo/uabpath/koka/dist-newstyle/build/x86_64-linux/ghc-9.10.3/koka-3.2.7/x/koka/build/koka/koka

# CI configuration (GitHub Actions, see .github/workflows/ci.yml)
build:ci --copt=-march=x86-64    # overrides -march=native: portable across runner CPU generations
build:ci --disk_cache=~/.cache/bazel-disk
build:ci --repository_cache=~/.cache/bazel-repo
test:ci --test_output=errors
